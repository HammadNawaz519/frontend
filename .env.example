# ============================================================
# Fleet Command System — Frontend Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# ============================================================

# ── Backend connection ──────────────────────────────────────
# The URL of your deployed backend server (e.g. Railway URL).
# If left blank, it defaults to localhost:8000 during local development.
VITE_API_URL=

# ── Map ─────────────────────────────────────────────────────
# Mapbox GL JS public access token.
VITE_MAPBOX_TOKEN=

# ── AI Advisor (Optional Frontend Execution) ────────────────
# If provided, the Fleet Advisor AI runs directly in the browser.
# If omitted, it will fall back to requesting it from the Backend API.
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
